# =====================================================
# FOCUS OS — Variáveis de Ambiente
# =====================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local para o repositório.
# No Vercel, configure estas variáveis em Project Settings → Environment Variables.

# -----------------------------------------------------
# Supabase (obrigatório)
# -----------------------------------------------------
# Encontre em: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NUNCA exponha ao browser. Usado apenas em API routes admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------
# ClickUp (opcional — apenas se o módulo CRM for usar sync)
# -----------------------------------------------------
# Token pessoal: https://app.clickup.com/settings/apps
# IMPORTANTE: mantido SOMENTE no servidor — nunca com prefixo NEXT_PUBLIC_
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=
CLICKUP_SPACE_ID=
CLICKUP_LIST_ID=

# -----------------------------------------------------
# App
# -----------------------------------------------------
# URL pública do app (usado em links de email, OAuth callbacks, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000
